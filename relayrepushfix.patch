+ingest pipeline, whose dedupe makes re-pushes no-ops.
+
+The receiver's DB lives on an ephemeral disk, so a redeploy can wipe it.
+Every push (including empty heartbeats) returns the remote DB's instance id;
+when it changes, the local cursor no longer reflects what the remote holds,
+so the pusher resets it and re-sends the full history.
 """
 
 from __future__ import annotations
@@ -26,6 +30,7 @@ from ..db import Database
 log = logging.getLogger(__name__)
 
 CURSOR_KEY = "relay.cursor"
+INSTANCE_KEY = "relay.remote_instance"
 USER_AGENT = f"meshradio/{__version__} (+https://github.com/baldwinm/meshradio)"
 
 
@@ -72,19 +77,38 @@ class RelayPusher:
     async def push_once(self, client: httpx.AsyncClient) -> int:
         cursor = await self.db.get_setting(CURSOR_KEY, "")
         messages, newest = await self.collect(cursor)
-        if not messages:
-            return 0
+        # Push even an empty batch: it doubles as a heartbeat whose reply
+        # carries the remote DB's instance id.
+        reply = await self._post(client, messages)
+        remote = str(reply.get("instance") or "")
+        known = await self.db.get_setting(INSTANCE_KEY, "")
+        if remote and remote != known:
+            if cursor:
+                # The remote DB isn't the one the cursor was advanced against
+                # (redeploy wiped it, or this pusher predates instance ids).
+                # Re-send everything; the receiver's dedupe absorbs overlap.
+                log.info("relay: remote DB is new, re-pushing full history")
+                messages, newest = await self.collect("")
+                reply = await self._post(client, messages)
+            await self.db.set_setting(INSTANCE_KEY, remote)
+        # Advance only after a confirmed 2xx so a failed push retries in full.
+        if newest != cursor:
+            await self.db.set_setting(CURSOR_KEY, newest)
+        if messages:
+            log.info(
+                "relay: pushed %d messages (%s new remotely)",
+                len(messages),
+                reply.get("inserted", "?"),
+            )
+        return len(messages)
+
+    async def _post(self, client: httpx.AsyncClient, messages: list[dict]) -> dict:
         resp = await client.post(
             self.config.push_url.rstrip("/") + "/api/ingest",
             json={"messages": messages},
         )
         resp.raise_for_status()
-        inserted = resp.json().get("inserted", "?")
-        # Advance only after a confirmed 2xx so a failed push retries in full.
-        if newest != cursor:
-            await self.db.set_setting(CURSOR_KEY, newest)
-        log.info("relay: pushed %d messages (%s new remotely)", len(messages), inserted)
-        return len(messages)
+        return resp.json()
 
