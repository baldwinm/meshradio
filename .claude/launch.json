{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "meshradio",
      "runtimeExecutable": ".venv/Scripts/python.exe",
      "runtimeArgs": ["-m", "meshradio.app", "-v"],
      "port": 8080
    },
    {
      "name": "meshradio-preview",
      "runtimeExecutable": ".venv/Scripts/python.exe",
      "runtimeArgs": ["-m", "meshradio.app", "-v", "--port", "8090"],
      "port": 8090
    },
    {
      "name": "meshradio-embed",
      "runtimeExecutable": ".venv/Scripts/python.exe",
      "runtimeArgs": ["-m", "meshradio.app", "-v", "--config", "meshradio.render.toml", "--port", "8091"],
      "port": 8091
    }
  ]
}
